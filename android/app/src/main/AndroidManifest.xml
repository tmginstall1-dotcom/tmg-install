<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:usesCleartextTraffic="false"
        android:theme="@style/AppTheme">

        <activity
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|locale|smallestScreenSize|screenLayout|uiMode|navigation"
            android:name=".MainActivity"
            android:label="@string/title_activity_main"
            android:theme="@style/AppTheme.NoActionBarLaunch"
            android:launchMode="singleTask"
            android:exported="true"
            android:windowSoftInputMode="adjustResize"
            android:hardwareAccelerated="true">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

        </activity>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths"></meta-data>
        </provider>

        <!--
            Background Geolocation foreground service.
            Runs as a foreground service so Android keeps it alive when the app
            is minimised or the screen is off. A persistent notification is shown
            (required by Android for foreground services of type "location").
        -->
        <service
            android:name="com.equimaps.capacitor_background_geolocation.BackgroundGeolocationService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="location" />

    </application>

    <!-- ── Core network permission ───────────────────────────────────────── -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- ── Location permissions ──────────────────────────────────────────── -->
    <!-- Coarse location (network-based) -->
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <!-- Fine location (GPS) -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <!--
        Background location — REQUIRED for tracking when the app is not visible.
        Android 10 (API 29) and above require this separate permission.
        The user will see a "Allow all the time" option in the permission dialog.
    -->
    <uses-permission android:name="android.permission.ACCESS_BACKGROUND_LOCATION" />

    <!-- ── Foreground service permissions ────────────────────────────────── -->
    <!-- Allows starting a foreground service -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <!-- Android 14 (API 34)+ additionally requires this for type="location" -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION" />
    <!-- Android 13 (API 33)+ requires this to show the tracking notification -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- ── Camera permission ──────────────────────────────────────────────── -->
    <!-- Required for staff photo check-in / check-out -->
    <uses-permission android:name="android.permission.CAMERA" />

    <!-- Hardware feature declarations -->
    <uses-feature android:name="android.hardware.location.gps" android:required="false" />
    <uses-feature android:name="android.hardware.camera" android:required="false" />

</manifest>
